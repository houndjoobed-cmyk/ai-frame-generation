# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Authentication (NextAuth)
AUTH_SECRET=your_auth_secret_here (generate with: openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000 (en production: https://votre-domaine.com)

# Social Auth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# KkiaPay (Sandbox/Prod)
NEXT_PUBLIC_KKIAPAY_PUBLIC_KEY=your_public_key
KKIAPAY_PRIVATE_KEY=your_private_key
KKIAPAY_SECRET_KEY=your_secret_key
KKIAPAY_WEBHOOK_SECRET=your_webhook_secret

# Brevo (Email Service)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_verified_sender_email@domain.com
